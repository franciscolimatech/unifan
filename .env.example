# ─── Cristóvão — Variáveis de Ambiente ───────────────────────────────────────
#
# Copie este arquivo para .env.local e preencha com os seus valores.
# NUNCA commite o .env.local no Git — ele está no .gitignore.
#
# Na Vercel, configure essas variáveis em:
#   Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Obtenha em: MongoDB Atlas → Connect → Drivers → Node.js
# Formato: mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nome do banco de dados no Atlas (criado automaticamente no primeiro insert)
MONGODB_DB_NAME=cristovao

# ── JWT ────────────────────────────────────────────────────────────────────────
# Gere um segredo forte (mínimo 64 bytes) com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_FORTE_DE_64_BYTES_OU_MAIS

# ── Termos de Uso ──────────────────────────────────────────────────────────────
# Incrementar esta versão forçará todos os usuários a reaceitar os termos
# na próxima vez que fizerem login.
VERSAO_TERMOS_ATUAL=1.0.0

# ── Ambiente ───────────────────────────────────────────────────────────────────
# A Vercel define NODE_ENV=production automaticamente. Em dev local:
NODE_ENV=development
